# ============================================================
#  ENV konventsiyasi (barcha .env* fayllar .gitignore'da)
#
#   .env.local        -> LOCAL developer   (npm run dev)      — faqat mahalliy
#   .env.development  -> DEV server         (npm run build:dev, `dev` branch)
#   .env.production   -> PROD server        (npm run build,     `main` branch)
#
#  CI/CD build vaqtida .env.development / .env.production fayllarini
#  GitHub Secrets (DEV_ENV_FILE / PROD_ENV_FILE) dan yaratadi.
#  Yangi loyihada: ushbu faylni nusxalab kerakli .env.* qiling.
# ============================================================

# API (REST)
VITE_API_URL=https://api.example.com
# WebSocket
VITE_SOCKET_URL=wss://api.example.com
VITE_SOCKET_SECRET=your_socket_jwt_token

# Eslatma: dev-mode (isModeDev) Vite MODE bo'yicha aniqlanadi (main.js),
# alohida VITE_APP_MODE env kerak emas: production => yopiq, development/local => ochiq.
VITE_OTP_EXPIRE_TIME=120000

# OnlyOffice
VITE_OFFICE_SERVER=https://office.example.com
VITE_CALLBACK_URL=https://api.example.com/api/v1/document/update
VITE_OFFICE_JWT_SECRET=your_onlyoffice_jwt_secret

# Analytics / reCAPTCHA
VITE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ============================================================
#  Deploy target — serverdagi .env ichida (GitHub Var/Secret emas).
#  DEV va PROD serverlar o'z .env ichida:
#    DEPLOY_PATH=/var/www/hrm_front/dist        # rsync target (nginx root)
#  CI (self-hosted runner) shu papkaga dist/ ni rsync qiladi.
# ============================================================

VITE_SEASON=spring
# spring = bahor
# summer = yoz
# autumn = kuz
# winter = qish
# hech qaysi fasl = null